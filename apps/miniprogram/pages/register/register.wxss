.login-page {
  min-height: 100vh;
  padding: 80rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.brand {
  text-align: center;
  margin-bottom: 64rpx;
}

.logo {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #34d399;
  letter-spacing: -1rpx;
}

.tagline {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}

.form {
  margin-bottom: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.input {
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #f8fafc;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.submit {
  margin-top: 12rpx;
  width: 100%;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  width: 100%;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.hint {
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
}

.hint-link {
  display: inline;
  color: #34d399;
  text-decoration: underline;
  margin-left: 8rpx;
}
