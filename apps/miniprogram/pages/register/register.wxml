<view class="login-page">
  <view class="brand">
    <text class="logo">PulseWatch</text>
    <text class="tagline">免费创建账号 · 开始监控</text>
  </view>

  <view class="form card">
    <view class="wechat-section">
      <navigator url="/pages/login/login" class="btn-wechat" open-type="switchTab">
        返回登录页 → 使用微信或手机号一键注册
      </navigator>
      <text class="wechat-hint">微信身份或手机号登录会自动创建账号，无需邮箱密码</text>
    </view>

    <view class="divider">
      <text class="divider-line"></text>
      <text class="divider-text">或</text>
      <text class="divider-line"></text>
    </view>

    <view wx:if="{{showForm}}" class="email-form">
      <view class="field">
        <text class="label">邮箱</text>
        <input class="input" type="text" placeholder="your@email.com" value="{{email}}" bindinput="onEmailInput" />
      </view>
      <view class="field">
        <text class="label">密码（至少8位）</text>
        <input class="input" password placeholder="密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <view class="field">
        <text class="label">显示名称</text>
        <input class="input" type="text" placeholder="您的名称" value="{{displayName}}" bindinput="onDisplayNameInput" />
      </view>
      <button class="btn-primary submit" loading="{{loading}}" disabled="{{loading}}" bindtap="onSubmit">
        注册
      </button>
    </view>

    <view wx:else>
      <button class="btn-secondary-outline" bindtap="toggleForm">使用邮箱注册（需 Web 端验证）</button>
    </view>
  </view>

  <view class="hint">
    <text>已有账号？</text>
    <navigator url="/pages/login/login" class="hint-link">去登录</navigator>
  </view>
</view>
