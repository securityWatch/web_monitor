<view class="container">
  <view class="header">
    <view class="header-row">
      <text class="title">监控概览</text>
      <button class="btn-add" bindtap="openNew">+ 新建</button>
    </view>
    <view class="summary-pills">
      <text class="pill pill-up">正常 {{summary.up}}</text>
      <text class="pill pill-down">故障 {{summary.down}}</text>
      <text class="pill">共 {{summary.total}}</text>
    </view>
    <view class="search-bar">
      <input class="search-input" placeholder="搜索监控名称或 URL…" value="{{search}}" bindinput="onSearchInput" />
    </view>
  </view>

  <view wx:if="{{error}}" class="error-box">{{error}}</view>

  <view wx:if="{{loading}}" class="empty">加载中…</view>

  <view wx:elif="{{monitors.length === 0}}" class="empty">
    <text>暂无监控项</text>
    <text class="empty-sub">点击「+ 新建」创建第一个监控</text>
  </view>

  <block wx:else>
    <view
      wx:for="{{filtered}}"
      wx:key="id"
      class="card monitor-card"
      data-id="{{item.id}}"
      bindtap="openDetail"
      bindlongpress="onLongPress"
    >
      <view class="row-top">
        <text class="card-title">{{item.name}}</text>
        <text class="badge badge-{{item.status}}">{{item.statusLabel}}</text>
      </view>
      <text class="card-sub url">{{item.targetUrl}}</text>
      <view class="row-meta">
        <text>上次检测 {{item.lastCheckText}}</text>
        <text>{{item.responseText}}</text>
        <text>24h {{item.uptimeText}}</text>
      </view>
    </view>
    <view class="longpress-hint">长按监控项可暂停、编辑或删除</view>
  </block>
</view>
