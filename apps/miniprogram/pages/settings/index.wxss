.profile .email {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-top: 8rpx;
}

.profile-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f3f4f6;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.wechat-label {
  display: block;
  margin-bottom: 4rpx;
}

.wechat-icon {
  font-size: 22rpx;
  color: #059669;
  font-weight: 500;
}

.display-name {
  display: block;
  margin-top: 4rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.plan-badge {
  display: inline-block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.section-subtitle {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin: 24rpx 0 12rpx;
}

.org-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-top: 8rpx;
}

.api-row {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.api-url {
  display: block;
  font-size: 24rpx;
  color: #059669;
  word-break: break-all;
}

.copy-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.hint {
  display: block;
  margin-top: 12rpx;
}

.stub-text {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

.stub-link {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
  word-break: break-all;
}

.bind-wechat {
  margin-top: 20rpx;
  width: 100%;
}

.logout-btn {
  margin-top: 32rpx;
  background: transparent;
  border: 1rpx solid #d1d5db;
  color: #dc2626;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  padding: 28rpx;
}

.version {
  display: block;
  text-align: center;
  margin-top: 32rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.global-logout {
  margin: 32rpx 0 48rpx;
}

/* Tab bar (settings inner) */
.tab-bar {
  margin-bottom: 20rpx;
}

.tab-scroll {
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 8rpx;
}

.tab-list {
  display: inline-flex;
  gap: 8rpx;
}

.tab-item {
  display: inline-block;
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
}

.tab-item.active {
  color: #111827;
  background: #f3f4f6;
  border-color: #d1d5db;
}

/* Fields */
.field {
  margin-bottom: 20rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.field-value {
  display: block;
  font-size: 28rpx;
  color: #374151;
}

.field-sub {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.input {
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 20rpx;
  color: #111827;
  font-size: 26rpx;
  height: 80rpx;
  line-height: 1;
  width: 100%;
  box-sizing: border-box;
}

.picker-value {
  display: block;
  min-height: 44rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #ffffff;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  margin-top: 8rpx;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

/* Toggles */
.toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 26rpx;
  color: #374151;
}

.toggle-row:last-child {
  border-bottom: none;
}

/* Messages */
.msg {
  font-size: 24rpx;
  padding: 12rpx;
  border-radius: 8rpx;
  margin: 12rpx 0;
  text-align: center;
}

.msg-ok {
  background: rgba(16, 185, 129, 0.08);
  color: #059669;
}

.msg-err {
  background: rgba(239, 68, 68, 0.05);
  color: #dc2626;
}

/* Stats */
.stat-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-item {
  flex: 1;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

/* Sessions */
.session-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  gap: 16rpx;
}

.session-info {
  flex: 1;
  min-width: 0;
}

.session-device {
  display: block;
  font-size: 24rpx;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-time {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.btn-danger-sm {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(239, 68, 68, 0.05);
  color: #dc2626;
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  flex-shrink: 0;
}

/* Team */
.member-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.member-name {
  font-size: 26rpx;
  color: #374151;
}

.member-role {
  font-size: 22rpx;
  color: #9ca3af;
}

.invite-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #6b7280;
}

.invite-pending {
  color: #d97706;
}

/* API Keys */
.apikey-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  flex-wrap: wrap;
}

.apikey-info {
  flex: 1;
  min-width: 0;
}

.apikey-name {
  display: block;
  font-size: 26rpx;
  color: #374151;
}

.apikey-preview {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  font-family: monospace;
}

.apikey-created {
  font-size: 20rpx;
  color: #9ca3af;
}

.new-key-box {
  margin-top: 20rpx;
  padding: 16rpx;
  background: rgba(16, 185, 129, 0.08);
  border: 1rpx solid rgba(16, 185, 129, 0.2);
  border-radius: 12rpx;
}

.new-key-label {
  display: block;
  font-size: 22rpx;
  color: #059669;
  margin-bottom: 8rpx;
}

.new-key-value {
  display: block;
  font-size: 22rpx;
  color: #111827;
  font-family: monospace;
  word-break: break-all;
}

/* Audit */
.audit-row {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.audit-action {
  display: block;
  font-size: 24rpx;
  color: #374151;
}

.audit-time {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.audit-detail {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

/* Billing */
.plan-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.founding-badge {
  font-size: 22rpx;
  color: #d97706;
  background: rgba(245, 158, 11, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
}

.report-box {
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(59, 130, 246, 0.05);
  border: 1rpx solid rgba(59, 130, 246, 0.15);
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #6b7280;
  max-height: 600rpx;
  overflow-y: auto;
  white-space: pre-wrap;
  word-break: break-all;
}

/* Loading & Empty */
.loading-inline {
  color: #9ca3af;
  font-size: 24rpx;
  padding: 24rpx 0;
  text-align: center;
}

.empty-inline {
  color: #9ca3af;
  font-size: 24rpx;
  padding: 24rpx 0;
  text-align: center;
}

.capitalize {
  text-transform: capitalize;
}

.channel-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.channel-info {
  flex: 1;
}

.channel-name {
  display: block;
  font-size: 26rpx;
  color: #374151;
}

.channel-type {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 2rpx;
}

.maint-row {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.maint-desc {
  display: block;
  font-size: 26rpx;
  color: #374151;
}

.maint-time {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.lang-row {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.lang-label {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #6b7280;
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
}

.lang-active {
  color: #059669;
  border-color: #059669;
  background: rgba(16, 185, 129, 0.06);
}

.nav-btn {
  margin-top: 16rpx;
  text-align: center;
  font-size: 26rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #ffffff;
  font-weight: 600;
  border: none;
  display: block;
}

.stub-link {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
  word-break: break-all;
}

.capitalize {
  text-transform: capitalize;
}
