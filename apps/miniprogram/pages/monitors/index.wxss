.header {
  margin-bottom: 24rpx;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  display: block;
}

.btn-add {
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #ffffff;
  font-weight: 600;
  border: none;
  line-height: 1;
}

.search-bar {
  margin-top: 16rpx;
}

.search-input {
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  color: #374151;
  font-size: 26rpx;
  width: 100%;
  box-sizing: border-box;
}

.summary-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
}

.pill-up {
  color: #059669;
  background: rgba(16, 185, 129, 0.1);
}

.pill-down {
  color: #dc2626;
  background: rgba(239, 68, 68, 0.1);
}

.monitor-card:active {
  opacity: 0.85;
}

.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.url {
  display: block;
  margin-top: 8rpx;
  word-break: break-all;
}

.row-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.longpress-hint {
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 16rpx;
}
