.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  background: #ffffff;
  border-top: 1rpx solid #e5e7eb;
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.tab-item.active {
  color: #10b981;
}

.tab-icon {
  font-size: 32rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
}
