.form-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.form-sub {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.input {
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #111827;
  font-size: 28rpx;
  width: 100%;
  height: 80rpx;
  line-height: 1;
  box-sizing: border-box;
}

.picker-value {
  display: flex;
  align-items: center;
  min-height: 80rpx;
}

.readonly {
  opacity: 0.6;
}

.textarea {
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 20rpx;
  color: #111827;
  font-size: 26rpx;
  width: 100%;
  height: 160rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

.advanced-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.advanced-toggle-text {
  font-size: 26rpx;
  color: #059669;
}

.advanced-toggle-icon {
  font-size: 20rpx;
  color: #059669;
}

.alert-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.alert-label {
  font-size: 24rpx;
  color: #6b7280;
  flex: 1;
}

.alert-input {
  width: 120rpx;
  text-align: center;
  padding: 16rpx;
  height: 64rpx;
}

.toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 26rpx;
  color: #374151;
}

.toggle-row:last-child {
  border-bottom: none;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #ffffff;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  width: 100%;
  padding: 26rpx;
  font-size: 28rpx;
  margin-top: 12rpx;
}

.btn-primary[disabled] {
  opacity: 0.6;
}
