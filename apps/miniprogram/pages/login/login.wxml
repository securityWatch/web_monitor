<view class="login-page">
  <view class="brand">
    <text class="logo">PulseWatch</text>
    <text class="tagline">网站监控 · 随时掌握服务状态</text>
  </view>

  <view wx:if="{{error}}" class="error-box">{{error}}</view>

  <view class="form card">
    <button
      wx:if="{{wechatEnabled}}"
      class="btn-wechat submit"
      loading="{{wechatLoading}}"
      disabled="{{wechatLoading || loading}}"
      bindtap="onWechatLogin"
    >
      微信一键登录
    </button>

    <view wx:if="{{wechatEnabled}}" class="divider">
      <text class="divider-line"></text>
      <text class="divider-text">或</text>
      <text class="divider-line"></text>
    </view>

    <button
      wx:if="{{!showEmailForm}}"
      class="btn-secondary-outline"
      bindtap="toggleEmailForm"
    >
      使用邮箱密码登录
    </button>

    <block wx:if="{{showEmailForm || !wechatEnabled}}">
      <view class="field">
        <text class="label">邮箱</text>
        <input
          class="input"
          type="text"
          placeholder="your@email.com"
          value="{{email}}"
          bindinput="onEmailInput"
        />
      </view>
      <view class="field">
        <text class="label">密码</text>
        <input
          class="input"
          password
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>
      <button
        class="btn-primary submit"
        loading="{{loading}}"
        disabled="{{loading || wechatLoading}}"
        bindtap="onSubmit"
      >
        登录
      </button>
    </block>
  </view>

  <view class="hint">
    <text wx:if="{{wechatEnabled}}">首次使用将自动创建 PulseWatch 账号</text>
    <text wx:else>微信一键登录未配置，请使用邮箱密码（与 Web 相同账号）</text>
    <text class="hint-sub">启用双因素认证的账号请先在 Web 端登录，或在 Web 设置中绑定微信</text>
  </view>
</view>
