<view class="container">
  <view class="card profile">
    <view class="profile-row">
      <image wx:if="{{user.avatarUrl}}" class="profile-avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
      <view class="profile-info">
        <text class="section-title">账号</text>
        <text wx:if="{{isWeChatAccount}}" class="wechat-label">
          <text class="wechat-icon">✓ 微信账号</text>
        </text>
        <text class="email">{{accountLabel}}</text>
        <text wx:if="{{user.displayName}}" class="display-name">{{user.displayName}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="section-title">组织</text>
    <text class="org-name">{{organization.name}}</text>
    <text class="card-sub">套餐 {{organization.planTier}}</text>
  </view>

  <view class="card">
    <text class="section-title">API 连接</text>
    <view class="api-row" bindtap="copyApiBase">
      <text class="api-url">{{apiBase}}</text>
      <text class="copy-hint">点击复制</text>
    </view>
    <text class="card-sub hint">修改地址请编辑 config/env.js 后重新编译</text>
  </view>

  <view wx:if="{{wechatEnabled}}" class="card">
    <text class="section-title">微信账号</text>
    <text class="card-sub">绑定后可在登录页使用微信一键登录此账号</text>
    <button class="btn-primary bind-wechat" loading="{{bindingWechat}}" bindtap="bindWechat">
      绑定当前微信
    </button>
  </view>

  <view class="card stub">
    <text class="section-title">更多设置</text>
    <text class="stub-text">通知偏好、告警渠道、团队管理等完整功能请使用 Web 端。</text>
    <text class="stub-link">https://gkao.com.cn/zh/settings</text>
  </view>

  <button class="logout-btn" bindtap="logout">退出登录</button>

  <text class="version">PulseWatch 小程序 v{{version}}</text>
</view>
