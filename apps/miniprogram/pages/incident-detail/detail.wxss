.meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.meta-item {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.meta-value {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #374151;
}

.capitalize {
  text-transform: capitalize;
}

.message-box {
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(245, 158, 11, 0.06);
  border-radius: 12rpx;
  border: 1rpx solid rgba(245, 158, 11, 0.15);
}

.message-text {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d1d5db;
  background: #f3f4f6;
  color: #374151;
  text-align: center;
  line-height: 1;
}

.action-edit {
  border-color: rgba(16, 185, 129, 0.3);
  color: #059669;
}

.timeline {
  position: relative;
  padding-left: 32rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 8rpx;
  bottom: 8rpx;
  width: 2rpx;
  background: #e5e7eb;
}

.timeline-item {
  position: relative;
  padding: 12rpx 0 12rpx 20rpx;
}

.timeline-dot {
  position: absolute;
  left: -28rpx;
  top: 18rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d1d5db;
}

.timeline-dot-start {
  background: #d97706;
}

.timeline-dot-end {
  background: #059669;
}

.timeline-content {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
}

.timeline-action {
  display: block;
  font-size: 26rpx;
  color: #374151;
}

.timeline-time {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.textarea {
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 20rpx;
  color: #111827;
  font-size: 26rpx;
  width: 100%;
  height: 160rpx;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #ffffff;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.empty-inline {
  color: #9ca3af;
  font-size: 24rpx;
  padding: 24rpx 0;
  text-align: center;
}
