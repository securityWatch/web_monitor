page {
  background-color: #f5f7fa;
  color: #374151;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx 140rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.card-sub {
  font-size: 24rpx;
  color: #9ca3af;
}

.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-up {
  background: rgba(16, 185, 129, 0.1);
  color: #059669;
}

.badge-down {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.badge-paused {
  background: rgba(156, 163, 175, 0.15);
  color: #6b7280;
}

.badge-pending {
  background: rgba(245, 158, 11, 0.1);
  color: #d97706;
}

.badge-open {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.badge-resolved {
  background: rgba(16, 185, 129, 0.1);
  color: #059669;
}

.empty {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #9ca3af;
}

.error-box {
  background: rgba(239, 68, 68, 0.05);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  color: #dc2626;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #ffffff;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.stat-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-item {
  flex: 1;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.stat-label {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}
