.greeting {
  margin-bottom: 24rpx;
}

.greeting-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.alert-banner {
  display: block;
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(239, 68, 68, 0.05);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  border-radius: 12rpx;
  color: #dc2626;
  font-size: 26rpx;
}

.all-ok {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #059669;
}

.kpi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.kpi-card {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
}

.kpi-danger {
  border-color: rgba(239, 68, 68, 0.2);
  background: rgba(239, 68, 68, 0.03);
}

.kpi-warn {
  border-color: rgba(245, 158, 11, 0.2);
  background: rgba(245, 158, 11, 0.03);
}

.kpi-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
}

.value-danger {
  color: #dc2626;
}

.value-warn {
  color: #d97706;
}

.kpi-label {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.kpi-sub {
  display: block;
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #9ca3af;
}

.chart-container {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
  height: 200rpx;
  padding: 16rpx 0;
  overflow-x: auto;
}

.chart-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 48rpx;
}

.chart-bar {
  width: 32rpx;
  min-height: 8rpx;
  background: linear-gradient(180deg, #34d399, #10b981);
  border-radius: 6rpx 6rpx 0 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.chart-ms {
  font-size: 16rpx;
  color: #059669;
  margin-top: -20rpx;
  white-space: nowrap;
}

.chart-label {
  font-size: 18rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  transform: rotate(-30deg);
  white-space: nowrap;
}

.section-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.incident-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.incident-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.incident-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-open { background: #dc2626; }
.dot-resolved { background: #059669; }

.incident-info {
  flex: 1;
}

.incident-name {
  display: block;
  font-size: 26rpx;
  color: #374151;
}

.incident-time {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 2rpx;
}

.fail-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 24rpx;
}

.fail-name { color: #374151; flex: 1; }
.fail-time { color: #9ca3af; }
.fail-code { color: #dc2626; }
