# Database — use existing systemd PostgreSQL; do not start postgres via Docker.
# Server (see DEPLOYMENT.md): postgresql://postgres:<url-encoded-pass>@127.0.0.1:6541/pulsewatch
DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:6541/pulsewatch

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production

# API
PORT=4000
# Comma-separated allowed browser origins (IP + domains). CORS_ORIGIN is legacy single-value fallback.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1
# Deploy only: APP_DOMAINS=gkao.com.cn,www.gkao.com.cn (also set NEXT_PUBLIC_APP_DOMAINS at web build)
NODE_ENV=development

# Email (console | smtp) — 163 example:
# SMTP_MODE=smtp
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-account@163.com
# SMTP_PASS=your-authorization-code
# SMTP_FROM=your-account@163.com
SMTP_MODE=console
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pulsewatch.io

# Frontend (browser uses same-origin /api via Nginx; SSR uses INTERNAL_API_URL)
INTERNAL_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Canonical origin for SEO (sitemap, Open Graph, JSON-LD). Production: http://gkao.com.cn
NEXT_PUBLIC_SITE_URL=http://gkao.com.cn
NEXT_PUBLIC_APP_DOMAINS=gkao.com.cn,www.gkao.com.cn
# Baidu Webmaster site verification meta (optional). See docs/SEO.md
BAIDU_SITE_VERIFICATION=
# Google Search Console HTML tag verification (optional). See docs/SEO.md
GOOGLE_SITE_VERIFICATION=

# Twilio (SMS / Voice — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Stripe billing (optional)
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Distributed probe workers (optional — set PROBE_DISPATCH=true on API)
PROBE_DISPATCH=false
PROBE_SECRET=change-me-probe-secret
PROBE_REGION=us-east
PROBE_API_URL=http://127.0.0.1:4000

# Object storage for screenshots (optional)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# WeChat mini program one-click login (wx.login → code2session)
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
# WeChat mini program message push (微信小程序后台 → 开发管理 → 消息推送)
# Token and EncodingAESKey from the WeChat Mini Program admin panel
WECHAT_MINI_TOKEN=
# 43-character base64 key (ends with =), required for security/compatible mode
WECHAT_MINI_AES_KEY=

# DeepSeek AI content recognition for tamper monitors (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Check results retention (days)
CHECK_RAW_RETENTION_DAYS=7
CHECK_TOTAL_RETENTION_DAYS=90

# Ops DingTalk robot — notify on new user registration and new monitor (optional)
DINGTALK_WEBHOOK_URL=
