.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
}

.btn-add {
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border: none;
  line-height: 1;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.channel-card {
  margin-bottom: 16rpx;
}

.channel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.channel-info {
  flex: 1;
  min-width: 0;
}

.channel-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.channel-type {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.channel-url {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  word-break: break-all;
}

.channel-event {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  margin-top: 6rpx;
}

.channel-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.action-sm {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #1e293b;
  color: #e2e8f0;
  border: 1rpx solid #334155;
  line-height: 1;
}

.action-test {
  border-color: rgba(52, 211, 153, 0.3);
  color: #34d399;
}

.action-del {
  border-color: rgba(248, 113, 113, 0.3);
  color: #f87171;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
}

.form-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
}

.input {
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 22rpx;
  color: #f8fafc;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 1;
  width: 100%;
  box-sizing: border-box;
}

.picker-value {
  display: flex;
  align-items: center;
  min-height: 80rpx;
}

.event-toggle {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #1a1a1a;
}

.event-label {
  font-size: 26rpx;
  color: #e2e8f0;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-primary[disabled] { opacity: 0.6; }

.btn-cancel {
  flex: 1;
  background: transparent;
  color: #64748b;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.error-box {
  background: rgba(248, 113, 113, 0.1);
  border: 1rpx solid rgba(248, 113, 113, 0.3);
  color: #fca5a5;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}
