.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
}

.btn-add {
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border: none;
  line-height: 1;
}

.page-card {
  margin-bottom: 16rpx;
}

.page-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.page-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.page-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
}

.page-slug {
  font-size: 24rpx;
  color: #34d399;
  font-family: monospace;
}

.page-domain {
  font-size: 22rpx;
  color: #94a3b8;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
}

.modal-scroll {
  overflow-y: auto;
}

.form-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
}

.input {
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 22rpx;
  color: #f8fafc;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 1;
  width: 100%;
  box-sizing: border-box;
}

.textarea {
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 20rpx;
  color: #f8fafc;
  font-size: 26rpx;
  width: 100%;
  height: 140rpx;
  box-sizing: border-box;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-primary[disabled] { opacity: 0.6; }

.btn-sm {
  margin-top: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
}

.btn-cancel {
  flex: 1;
  background: transparent;
  color: #64748b;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.close-btn {
  font-size: 32rpx;
  color: #64748b;
  padding: 8rpx;
}

.announce-row {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 16rpx;
  background: #1a1a1a;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.announce-text {
  font-size: 26rpx;
  color: #e2e8f0;
}

.announce-time {
  font-size: 20rpx;
  color: #64748b;
}

.btn-delete-sm {
  align-self: flex-end;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(248, 113, 113, 0.1);
  color: #f87171;
  border: 1rpx solid rgba(248, 113, 113, 0.2);
  margin-top: 8rpx;
}

.section-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.empty-inline {
  color: #64748b;
  font-size: 24rpx;
  padding: 24rpx 0;
  text-align: center;
}

.pill {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
  background: #1e293b;
  color: #94a3b8;
}

.pill-up {
  background: rgba(52, 211, 153, 0.15);
  color: #34d399;
}
