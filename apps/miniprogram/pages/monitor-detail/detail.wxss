.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 24rpx;
}

.meta-item {
  background: #1a1a1a;
  border-radius: 12rpx;
  padding: 16rpx;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
}

.meta-value {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #e2e8f0;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 16rpx;
}

.check-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #262626;
  font-size: 24rpx;
}

.check-row:last-child {
  border-bottom: none;
}

.check-left {
  flex: 1;
}

.check-status {
  display: block;
  font-weight: 600;
}

.check-status.ok {
  color: #34d399;
}

.check-status.fail {
  color: #f87171;
}

.check-time {
  display: block;
  margin-top: 4rpx;
  color: #64748b;
  font-size: 22rpx;
}

.check-right {
  text-align: right;
  color: #94a3b8;
  font-size: 22rpx;
}

.empty-inline {
  color: #64748b;
  font-size: 24rpx;
  padding: 16rpx 0;
}

.badge-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.badge-pending {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 12rpx;
  font-style: italic;
}

.badge-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.badge-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  background: #1e293b;
  color: #e2e8f0;
  border: 1rpx solid #334155;
}

.badge-btn-warn {
  background: rgba(239, 68, 68, 0.15);
  border-color: rgba(239, 68, 68, 0.3);
  color: #fca5a5;
}

.pill {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
  background: #1e293b;
  color: #94a3b8;
}

.pill-up {
  background: rgba(52, 211, 153, 0.15);
  color: #34d399;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 120rpx;
  font-size: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #334155;
  background: #1e293b;
  color: #e2e8f0;
  text-align: center;
  line-height: 1;
}

.action-edit {
  border-color: rgba(52, 211, 153, 0.3);
  color: #34d399;
}

.action-pause {
  border-color: rgba(251, 191, 36, 0.3);
  color: #fbbf24;
}

.action-resume {
  border-color: rgba(52, 211, 153, 0.3);
  color: #34d399;
}

.action-delete {
  border-color: rgba(248, 113, 113, 0.3);
  color: #f87171;
}
