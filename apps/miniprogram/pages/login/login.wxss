.login-page {
  min-height: 100vh;
  padding: 80rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.brand {
  text-align: center;
  margin-bottom: 64rpx;
}

.logo {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #34d399;
  letter-spacing: -1rpx;
}

.tagline {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}

.form {
  margin-bottom: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.input {
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #f8fafc;
  font-size: 28rpx;
}

.submit {
  margin-top: 12rpx;
  width: 100%;
}

.btn-wechat {
  background: #07c160;
  color: #fff;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.btn-wechat[disabled] {
  opacity: 0.6;
}

.btn-secondary-outline {
  background: transparent;
  color: #94a3b8;
  font-size: 26rpx;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  margin-top: 8rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 28rpx 0 20rpx;
  gap: 16rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #333;
}

.divider-text {
  font-size: 24rpx;
  color: #64748b;
}

.hint {
  text-align: center;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.8;
}

.hint-sub {
  display: block;
  font-size: 22rpx;
  color: #475569;
}
