.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
  display: block;
  margin-bottom: 16rpx;
}

.summary-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #1a1a1a;
  color: #94a3b8;
}

.pill-up {
  color: #34d399;
  background: rgba(52, 211, 153, 0.12);
}

.pill-down {
  color: #f87171;
  background: rgba(248, 113, 113, 0.12);
}

.monitor-card:active {
  opacity: 0.85;
}

.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.url {
  display: block;
  margin-top: 8rpx;
  word-break: break-all;
}

.row-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #64748b;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
}
