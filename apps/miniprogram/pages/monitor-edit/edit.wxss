.form-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
}

.form-sub {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
}

.input {
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #f8fafc;
  font-size: 28rpx;
  width: 100%;
  height: 80rpx;
  line-height: 1;
  box-sizing: border-box;
}

.picker-value {
  display: block;
  min-height: 44rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  width: 100%;
  padding: 26rpx;
  font-size: 28rpx;
  margin-top: 12rpx;
}

.btn-primary[disabled] {
  opacity: 0.6;
}
