.login-page {
  min-height: 100vh;
  padding: 80rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.brand {
  text-align: center;
  margin-bottom: 64rpx;
}

.logo {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #34d399;
  letter-spacing: -1rpx;
}

.tagline {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}

.form {
  margin-bottom: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.input {
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #f8fafc;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 1;
  width: 100%;
  box-sizing: border-box;
}

.submit {
  margin-top: 12rpx;
  width: 100%;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  width: 100%;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.btn-secondary-outline {
  background: transparent;
  color: #94a3b8;
  font-size: 26rpx;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  margin-top: 8rpx;
  width: 100%;
  padding: 24rpx;
}

.btn-wechat {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  background: #07c160;
  color: #fff;
  font-weight: 600;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  text-decoration: none;
}

.wechat-section {
  text-align: center;
}

.wechat-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.divider {
  display: flex;
  align-items: center;
  margin: 28rpx 0 20rpx;
  gap: 16rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #333;
}

.divider-text {
  font-size: 24rpx;
  color: #64748b;
}

.hint {
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
}

.hint-link {
  display: inline;
  color: #34d399;
  text-decoration: underline;
  margin-left: 8rpx;
}
