page {
  background-color: #0a0a0a;
  color: #e2e8f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx 140rpx;
}

.card {
  background: #141414;
  border: 1rpx solid #262626;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 8rpx;
}

.card-sub {
  font-size: 24rpx;
  color: #64748b;
}

.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-up {
  background: rgba(52, 211, 153, 0.15);
  color: #34d399;
}

.badge-down {
  background: rgba(248, 113, 113, 0.15);
  color: #f87171;
}

.badge-paused {
  background: rgba(148, 163, 184, 0.15);
  color: #94a3b8;
}

.badge-pending {
  background: rgba(251, 191, 36, 0.15);
  color: #fbbf24;
}

.badge-open {
  background: rgba(248, 113, 113, 0.15);
  color: #f87171;
}

.badge-resolved {
  background: rgba(52, 211, 153, 0.15);
  color: #34d399;
}

.empty {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #64748b;
}

.error-box {
  background: rgba(248, 113, 113, 0.1);
  border: 1rpx solid rgba(248, 113, 113, 0.3);
  color: #fca5a5;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.stat-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-item {
  flex: 1;
  background: #1a1a1a;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
}

.stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}
