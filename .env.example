# Database
DATABASE_URL=postgresql://pulsewatch:pulsewatch@localhost:5432/pulsewatch

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production

# API
PORT=4000
# Comma-separated allowed browser origins (IP + domains). CORS_ORIGIN is legacy single-value fallback.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1
# Deploy only: APP_DOMAINS=gkao.com.cn,www.gkao.com.cn
NODE_ENV=development

# Email (console | smtp)
SMTP_MODE=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pulsewatch.io

# Frontend (browser uses same-origin /api via Nginx; SSR uses INTERNAL_API_URL)
INTERNAL_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
