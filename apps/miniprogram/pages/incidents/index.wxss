.filters {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.filter-btn {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #f3f4f6;
  color: #6b7280;
}

.filter-btn.active {
  background: rgba(16, 185, 129, 0.1);
  color: #059669;
}

.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.row-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.message {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.5;
}
