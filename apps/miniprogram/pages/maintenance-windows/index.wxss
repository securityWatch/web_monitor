.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.btn-add {
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #ffffff;
  font-weight: 600;
  border: none;
  line-height: 1;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.maint-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.maint-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.maint-meta {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.maint-msg {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  font-style: italic;
}

.action-del {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(239, 68, 68, 0.05);
  color: #dc2626;
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  line-height: 1;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
}

.form-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.input {
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 22rpx;
  color: #111827;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 1;
  width: 100%;
  box-sizing: border-box;
}

.picker-value {
  display: flex;
  align-items: center;
  min-height: 80rpx;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #ffffff;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-primary[disabled] { opacity: 0.6; }

.btn-cancel {
  flex: 1;
  background: transparent;
  color: #6b7280;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.error-box {
  background: rgba(239, 68, 68, 0.05);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  color: #dc2626;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}
