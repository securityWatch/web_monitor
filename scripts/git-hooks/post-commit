#!/bin/sh
# Auto-sync OSS mirror after commits on main (opt-in via npm run hooks:install).
# Skip: SKIP_OSS_SYNC=1 git commit ...
# Only runs when pushed state matches (post-push is not a native git hook).

branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || exit 0
[ "$branch" = "main" ] || exit 0
[ "$SKIP_OSS_SYNC" = "1" ] && exit 0
[ "$OSS_AUTO_SYNC" != "1" ] && exit 0

# Sync only if working tree is clean and branch is ahead of origin (about to be or was pushed)
if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
  exit 0
fi

ahead=$(git rev-list --count origin/main..HEAD 2>/dev/null || echo 0)
[ "$ahead" = "0" ] || exit 0

root=$(git rev-parse --show-toplevel)
node "$root/scripts/sync-web-monitor-oss.js" || true
