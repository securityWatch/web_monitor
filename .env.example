# Database
DATABASE_URL=postgresql://pulsewatch:pulsewatch@localhost:5432/pulsewatch

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production

# API
PORT=4000
# Comma-separated allowed browser origins (IP + domains). CORS_ORIGIN is legacy single-value fallback.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1
# Deploy only: APP_DOMAINS=gkao.com.cn,www.gkao.com.cn
NODE_ENV=development

# Email (console | smtp)
SMTP_MODE=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pulsewatch.io

# Frontend (browser uses same-origin /api via Nginx; SSR uses INTERNAL_API_URL)
INTERNAL_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Twilio (SMS / Voice — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Distributed probe workers (optional — set PROBE_DISPATCH=true on API)
PROBE_DISPATCH=false
PROBE_SECRET=change-me-probe-secret
PROBE_REGION=us-east
PROBE_API_URL=http://127.0.0.1:4000

# Object storage for screenshots (optional)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
