.meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.meta-item {
  background: #1a1a1a;
  border-radius: 12rpx;
  padding: 16rpx;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
}

.meta-value {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #e2e8f0;
}

.capitalize {
  text-transform: capitalize;
}

.message-box {
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(251, 191, 36, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid rgba(251, 191, 36, 0.15);
}

.message-text {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #e2e8f0;
  line-height: 1.6;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #334155;
  background: #1e293b;
  color: #e2e8f0;
  text-align: center;
  line-height: 1;
}

.action-edit {
  border-color: rgba(52, 211, 153, 0.3);
  color: #34d399;
}

.timeline {
  position: relative;
  padding-left: 32rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 8rpx;
  bottom: 8rpx;
  width: 2rpx;
  background: #262626;
}

.timeline-item {
  position: relative;
  padding: 12rpx 0 12rpx 20rpx;
}

.timeline-dot {
  position: absolute;
  left: -28rpx;
  top: 18rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #334155;
}

.timeline-dot-start {
  background: #fbbf24;
}

.timeline-dot-end {
  background: #34d399;
}

.timeline-content {
  background: #1a1a1a;
  border-radius: 12rpx;
  padding: 16rpx;
}

.timeline-action {
  display: block;
  font-size: 26rpx;
  color: #e2e8f0;
}

.timeline-time {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.textarea {
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 20rpx;
  color: #f8fafc;
  font-size: 26rpx;
  width: 100%;
  height: 160rpx;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #0a0a0a;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.empty-inline {
  color: #64748b;
  font-size: 24rpx;
  padding: 24rpx 0;
  text-align: center;
}
