.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 24rpx;
}

.meta-item {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.meta-value {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #374151;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.check-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 24rpx;
}

.check-row:last-child {
  border-bottom: none;
}

.check-left {
  flex: 1;
}

.check-status {
  display: block;
  font-weight: 600;
}

.check-status.ok {
  color: #059669;
}

.check-status.fail {
  color: #dc2626;
}

.check-time {
  display: block;
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 22rpx;
}

.check-right {
  text-align: right;
  color: #6b7280;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.empty-inline {
  color: #9ca3af;
  font-size: 24rpx;
  padding: 16rpx 0;
}

.badge-desc {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.badge-pending {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 12rpx;
  font-style: italic;
}

.badge-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.badge-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  color: #374151;
  border: 1rpx solid #d1d5db;
}

.badge-btn-warn {
  background: rgba(239, 68, 68, 0.05);
  border-color: rgba(239, 68, 68, 0.3);
  color: #dc2626;
}

.pill {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
  background: #f3f4f6;
  color: #6b7280;
}

.pill-up {
  background: rgba(16, 185, 129, 0.1);
  color: #059669;
}

.error-detail-box {
  margin-top: 8rpx;
  padding: 16rpx;
  background: rgba(239, 68, 68, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(239, 68, 68, 0.15);
}

.error-detail-label {
  display: block;
  font-size: 22rpx;
  color: #dc2626;
  margin-bottom: 8rpx;
}

.error-detail-text {
  display: block;
  font-size: 22rpx;
  color: #dc2626;
  line-height: 1.5;
  word-break: break-all;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 120rpx;
  font-size: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d1d5db;
  background: #f3f4f6;
  color: #374151;
  text-align: center;
  line-height: 1;
}

.action-edit {
  border-color: rgba(16, 185, 129, 0.3);
  color: #059669;
}

.action-pause {
  border-color: rgba(245, 158, 11, 0.3);
  color: #d97706;
}

.action-resume {
  border-color: rgba(16, 185, 129, 0.3);
  color: #059669;
}

.action-delete {
  border-color: rgba(239, 68, 68, 0.3);
  color: #dc2626;
}
