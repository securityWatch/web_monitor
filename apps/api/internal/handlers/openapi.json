{
  "openapi": "3.1.0",
  "info": {
    "title": "PulseWatch API",
    "version": "1.0.0",
    "description": "REST API for PulseWatch uptime monitoring"
  },
  "servers": [{ "url": "/api/v1" }],
  "paths": {
    "/health": { "get": { "summary": "API health check" } },
    "/auth/login": {
      "post": {
        "summary": "Login with email and password",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" }, "password": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Auth tokens or TOTP challenge" } }
      }
    },
    "/auth/register": { "post": { "summary": "Register new account" } },
    "/auth/refresh": { "post": { "summary": "Refresh access token" } },
    "/auth/forgot-password": { "post": { "summary": "Request password reset email" } },
    "/auth/reset-password": { "post": { "summary": "Reset password with token" } },
    "/auth/verify-email": { "post": { "summary": "Verify account email" } },
    "/auth/verify-email/resend": { "post": { "summary": "Resend verification email", "security": [{ "bearerAuth": [] }] } },
    "/auth/magic-link": { "post": { "summary": "Request magic login link" } },
    "/auth/magic": { "get": { "summary": "Complete magic-link login" } },
    "/auth/totp/verify": { "post": { "summary": "Verify TOTP challenge" } },
    "/auth/providers": { "get": { "summary": "List configured OAuth providers" } },
    "/auth/oauth/{provider}/start": { "get": { "summary": "Start OAuth login" } },
    "/auth/oauth/{provider}/callback": { "get": { "summary": "OAuth callback" } },
    "/auth/sso/start": { "get": { "summary": "Start organization SSO discovery" } },
    "/me": { "get": { "summary": "Current user profile", "security": [{ "bearerAuth": [] }] } },
    "/me/profile": { "patch": { "summary": "Update current user profile", "security": [{ "bearerAuth": [] }] } },
    "/me/password/change": { "post": { "summary": "Change password", "security": [{ "bearerAuth": [] }] } },
    "/me/email/change": { "post": { "summary": "Change email", "security": [{ "bearerAuth": [] }] } },
    "/me/notifications": { "patch": { "summary": "Update notification preferences", "security": [{ "bearerAuth": [] }] } },
    "/me/onboarding": { "patch": { "summary": "Update onboarding state", "security": [{ "bearerAuth": [] }] } },
    "/me/totp/setup": { "post": { "summary": "Create TOTP enrollment secret", "security": [{ "bearerAuth": [] }] } },
    "/me/totp/enable": { "post": { "summary": "Enable TOTP", "security": [{ "bearerAuth": [] }] } },
    "/me/totp/disable": { "post": { "summary": "Disable TOTP", "security": [{ "bearerAuth": [] }] } },
    "/me/switch-org": { "post": { "summary": "Switch active organization", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/dashboard": { "get": { "summary": "Organization dashboard metrics", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/monitors": {
      "get": { "summary": "List monitors", "security": [{ "bearerAuth": [] }] },
      "post": { "summary": "Create monitor", "security": [{ "bearerAuth": [] }] }
    },
    "/orgs/{orgId}/monitors/batch": { "patch": { "summary": "Batch pause, resume, or delete monitors", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/monitors/{id}": {
      "get": { "summary": "Get monitor", "security": [{ "bearerAuth": [] }] },
      "patch": { "summary": "Update monitor", "security": [{ "bearerAuth": [] }] },
      "delete": { "summary": "Delete monitor", "security": [{ "bearerAuth": [] }] }
    },
    "/orgs/{orgId}/monitors/{id}/checks": { "get": { "summary": "List monitor check results", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/monitors/{id}/stats": { "get": { "summary": "Monitor statistics and trend", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/monitors/{id}/artifacts": { "get": { "summary": "List monitor forensic artifacts", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/monitors/{id}/baseline": { "post": { "summary": "Capture DNS or tamper baseline", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/incidents": { "get": { "summary": "List incidents", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/incidents/{incidentId}": { "get": { "summary": "Get incident detail", "security": [{ "bearerAuth": [] }] }, "patch": { "summary": "Update incident workflow fields", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/incidents/{incidentId}/notes": { "post": { "summary": "Add incident note", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/alert-channels": { "get": { "summary": "List alert channels" }, "post": { "summary": "Create alert channel" } },
    "/orgs/{orgId}/alert-channels/{channelId}": { "patch": { "summary": "Update alert channel" }, "delete": { "summary": "Delete alert channel" } },
    "/orgs/{orgId}/alert-channels/{channelId}/test": { "post": { "summary": "Send alert-channel test" } },
    "/orgs/{orgId}/status-pages": { "get": { "summary": "List status pages", "security": [{ "bearerAuth": [] }] }, "post": { "summary": "Create status page", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/status-pages/{pageId}": { "get": { "summary": "Get status page", "security": [{ "bearerAuth": [] }] }, "patch": { "summary": "Update status page", "security": [{ "bearerAuth": [] }] }, "delete": { "summary": "Delete status page", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/status-pages/{pageId}/announcements": { "get": { "summary": "List status page announcements" }, "post": { "summary": "Create status page announcement" } },
    "/orgs/{orgId}/on-call/schedules": { "get": { "summary": "List on-call schedules", "security": [{ "bearerAuth": [] }] }, "post": { "summary": "Create on-call schedule", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/on-call/alerts": { "get": { "summary": "List pending on-call alerts", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/on-call/alerts/{alertId}/ack": { "post": { "summary": "Acknowledge on-call alert", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/sso": { "get": { "summary": "Get organization SSO config", "security": [{ "bearerAuth": [] }] }, "put": { "summary": "Upsert organization SSO config", "security": [{ "bearerAuth": [] }] } },
    "/orgs/{orgId}/maintenance-windows": { "get": { "summary": "List maintenance windows" }, "post": { "summary": "Create maintenance window" } },
    "/orgs/{orgId}/maintenance-windows/{windowId}": { "delete": { "summary": "Delete maintenance window" } },
    "/orgs/{orgId}/billing/checkout": { "post": { "summary": "Create Stripe Checkout session for pro/team/business" } },
    "/billing/webhook": { "post": { "summary": "Stripe webhook endpoint" } },
    "/heartbeat/{token}": { "post": { "summary": "Heartbeat monitor ping" } },
    "/orgs/{orgId}/api-keys": { "get": { "summary": "List API keys" }, "post": { "summary": "Create API key" } },
    "/orgs/{orgId}/api-keys/{keyId}": { "delete": { "summary": "Revoke API key" } },
    "/orgs/{orgId}/audit-logs": { "get": { "summary": "List audit logs" } },
    "/orgs/{orgId}/members": { "get": { "summary": "List organization members" } },
    "/orgs/{orgId}/invitations": { "post": { "summary": "Create organization invitation" } },
    "/orgs/{orgId}/reports/sla.csv": { "get": { "summary": "Export SLA CSV" } },
    "/orgs/{orgId}/reports/sla.html": { "get": { "summary": "Export SLA HTML" } },
    "/public/status/{slug}": { "get": { "summary": "Public status page" } },
    "/auth/wechat/miniprogram/status": { "get": { "summary": "Whether WeChat mini program login is configured" } },
    "/auth/wechat/miniprogram": { "post": { "summary": "WeChat mini program login or auto-register via wx.login code" } },
    "/me/wechat/miniprogram/bind": { "post": { "summary": "Link WeChat mini program to current user", "security": [{ "bearerAuth": [] }] } },
    "/public/status-domain": { "get": { "summary": "Public status page by custom domain" } },
    "/public/status/{slug}/subscribe": { "post": { "summary": "Subscribe to status page updates" } },
    "/public/status/{slug}/subscribe/confirm": { "post": { "summary": "Confirm status page subscription" } },
    "/public/founding-count": { "get": { "summary": "Remaining founding-member slots" } },
    "/public/ssl-check": { "get": { "summary": "SSL certificate check", "parameters": [{ "name": "host", "in": "query", "required": true }] } }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "description": "JWT or API key (pw_live_...)" }
    }
  }
}
