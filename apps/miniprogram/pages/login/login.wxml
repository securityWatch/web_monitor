<view class="login-page">
  <view class="brand">
    <text class="logo">PulseWatch</text>
    <text class="tagline">网站监控 · 随时掌握服务状态</text>
  </view>

  <view wx:if="{{error}}" class="error-box">{{error}}</view>

  <view class="form card">
    <block wx:if="{{wechatEnabled}}">
      <view class="wechat-section">
        <button
          class="btn-wechat"
          loading="{{wechatLoading}}"
          disabled="{{wechatLoading || loading}}"
          bindtap="getUserProfile"
        >
          <image
            wx:if="{{userInfo && userInfo.avatarUrl}}"
            class="btn-avatar"
            src="{{userInfo.avatarUrl}}"
            mode="aspectFill"
          />
          微信快捷登录
        </button>
        <text class="wechat-hint">使用微信身份创建或登录账号</text>
      </view>

      <view class="divider">
        <text class="divider-line"></text>
        <text class="divider-text">或</text>
        <text class="divider-line"></text>
      </view>

      <view class="wechat-section">
        <button
          class="btn-phone"
          loading="{{phoneLoading}}"
          disabled="{{phoneLoading || wechatLoading || loading}}"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
        >
          手机号一键登录
        </button>
        <text class="wechat-hint">使用微信绑定的手机号快速注册/登录</text>
      </view>

      <view class="divider">
        <text class="divider-line"></text>
        <text class="divider-text">或</text>
        <text class="divider-line"></text>
      </view>
    </block>

    <button
      wx:if="{{!showEmailForm && !wechatEnabled}}"
      class="btn-secondary-outline"
      bindtap="toggleEmailForm"
    >
      使用邮箱密码登录
    </button>

    <block wx:if="{{showEmailForm || !wechatEnabled}}">
      <view class="field">
        <text class="label">邮箱</text>
        <input
          class="input"
          type="text"
          placeholder="your@email.com"
          value="{{email}}"
          bindinput="onEmailInput"
        />
      </view>
      <view class="field">
        <text class="label">密码</text>
        <input
          class="input"
          password
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>
      <button
        class="btn-primary submit"
        loading="{{loading}}"
        disabled="{{loading || wechatLoading}}"
        bindtap="onSubmit"
      >
        登录
      </button>
      <view wx:if="{{!wechatEnabled}}" class="no-wechat-hint">
        <text>请联系管理员配置微信小程序登录</text>
      </view>
    </block>
  </view>

  <view class="hint">
    <text wx:if="{{wechatEnabled}}">自动注册：使用微信身份或手机号创建一个 PulseWatch 账号，无需邮箱密码</text>
    <text wx:else>微信一键登录未配置，请使用邮箱密码</text>
  </view>
  <view class="register-link">
    <text>没有账号？</text>
    <navigator url="/pages/register/register" class="hint-link">免费注册</navigator>
  </view>
</view>